# ── LLM ─────────────────────────────────────────────────────
OPENROUTER_API_KEY=                    # Dev tier: Qwen3/DeepSeek (Days 1-4, budget $4)
ANTHROPIC_API_KEY=                     # Eval tier: Claude Sonnet 4.6 (Day 5 only, budget $12)

# ── EMAIL ────────────────────────────────────────────────────
RESEND_API_KEY=                        # From resend.com dashboard
RESEND_FROM_EMAIL=                     # e.g. outreach@yourdomain.com
RESEND_WEBHOOK_SECRET=                 # From Resend dashboard → Webhooks

# ── SMS ──────────────────────────────────────────────────────
AT_API_KEY=                            # Africa's Talking API key
AT_USERNAME=                           # Africa's Talking username (sandbox)
AT_SHORT_CODE=                         # Your virtual short code e.g. 20880
AT_SENDER_ID=                          # Optional sender name

# ── CRM ──────────────────────────────────────────────────────
HUBSPOT_ACCESS_TOKEN=                  # Private app token from HubSpot dev sandbox
HUBSPOT_PORTAL_ID=                     # Your sandbox portal ID
# Set true only after creating matching custom contact properties in HubSpot (see hubspot_mcp enrichment keys).
HUBSPOT_SYNC_CUSTOM_PROPERTIES=false

# ── CALENDAR ─────────────────────────────────────────────────
CALCOM_API_KEY=                        # Cal.com API key
CALCOM_EVENT_TYPE_ID=                  # 30-min discovery call event type ID
CALCOM_WEBHOOK_SECRET=                 # Cal.com webhook secret

# ── OBSERVABILITY (Langfuse) ──────────────────────────────────
LANGFUSE_PUBLIC_KEY=                   # pk-lf-... from project settings
LANGFUSE_SECRET_KEY=                   # sk-lf-... from project settings
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── DATABASE ─────────────────────────────────────────────────
DB_PASSWORD=                      # Database password for local development
DATABASE_URL=postgresql://ce_user:${DB_PASSWORD}@localhost:5432/conversion_engine
REDIS_URL=redis://localhost:6379/0

# ── DEPLOYMENT ───────────────────────────────────────────────
RENDER_WEBHOOK_URL=                    # Your Render public URL e.g. https://yourapp.onrender.com
# Local webhooks: run `ngrok http 8000`, then register these paths on each provider:
#   RESEND  -> WEBHOOK_PUBLIC_BASE/webhooks/email
#   Cal.com -> WEBHOOK_PUBLIC_BASE/webhooks/cal
#   AT SMS  -> WEBHOOK_PUBLIC_BASE/webhooks/sms
# (HubSpot: no inbound webhook in this repo — API calls HubSpot with HUBSPOT_ACCESS_TOKEN.)
WEBHOOK_PUBLIC_BASE=                   # e.g. https://abc123.ngrok-free.app (no trailing slash)
ENVIRONMENT=development                # development | production
KILL_SWITCH=true                       # true = suppress Resend/SMS (DEFAULT for demos)
                                       # false = live outbound (local/staging E2E)
# Development only: if true, deliver real email/SMS even when KILL_SWITCH=true (never use in production).
LIVE_OUTREACH=false
# Must be 1 when using in-memory dashboard workspace (Uvicorn --workers 1).
WEB_CONCURRENCY=1
# Comma-separated CORS origins (dashboard). Default in config includes localhost dev ports.
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Human-in-the-loop: require POST /api/outreach/approve before first email (recommended in production).
# REQUIRE_HUMAN_APPROVAL=true
# Block sends when JSON Schema validation fails for brief projections.
# ENFORCE_JSON_SCHEMA=false
# Cal.com: booking question slug to pre-fill with company name (calendar/event title). Empty = omit.
CALCOM_BOOKING_TITLE_SLUG=title
# First-boot data policy acknowledgement marker (see tenacious_sales_data/policy/acknowledgement.md)
# DATA_HANDLING_ACK_FILE=.data_handling_acknowledged

# ── DATA SOURCES ─────────────────────────────────────────────
CRUNCHBASE_CSV_PATH=./data/crunchbase-companies-information.csv
LAYOFFS_CSV_PATH=./data/layoffs.csv
JOB_POSTS_SNAPSHOT_DIR=./data/job_posts_snapshot_apr2026